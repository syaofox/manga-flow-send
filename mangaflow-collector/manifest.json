{
  "manifest_version": 3,
  "name": "Mangaaflow 收藏助手",
  "version": "1.0.0",
  "description": "一键将漫画添加到 Mangaaflow 收藏",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost:8000"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://baozimh.com/*",
        "*://cn.baozimh.com/*",
        "*://tw.baozimh.com/*",
        "*://www.baozimh.com/*",
        "*://manhuagui.com/*",
        "*://www.manhuagui.com/*",
        "*://tw.manhuagui.com/*",
        "*://18comic.vip/*",
        "*://18comic.ink/*",
        "*://jmcomic-zzz.one/*",
        "*://jmcomic-zzz.org/*",
        "*://wnacg.com/*",
        "*://www.wnacg.com/*",
        "*://wnacg05.cc/*",
        "*://wnacg.cloud/*",
        "*://love4u.net/*",
        "*://mycomic.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}